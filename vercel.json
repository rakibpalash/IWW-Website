{
  "buildCommand": null,
  "outputDirectory": ".",
  "devCommand": null,
  "installCommand": null,
  "framework": null,
  "rewrites": [
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/blog/",
      "destination": "/blog.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blogs/:slug.html"
    },
    {
      "source": "/blog/:slug/",
      "destination": "/blogs/:slug.html"
    },
    {
      "source": "/((?!assets|\\.[\\w]+$).*)",
      "destination": "/index.html"
    }
  ]
}
